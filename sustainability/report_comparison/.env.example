# Request form (CTA) — server-side only; set these in the Vercel project.
# The recipient address lives ONLY here, never in client code (masked).

# Where "add a company / new category" requests are emailed.
# Set the real address only in Vercel — keep it out of the repo (masked).
REQUEST_TO_EMAIL=owner@example.com

# Resend API key (https://resend.com) used to deliver the email:
RESEND_API_KEY=

# Optional "from" address. Defaults to "ESG Tracker <onboarding@resend.dev>".
# Use a verified domain sender in production, e.g. "ESG Tracker <no-reply@pris.la>".
# REQUEST_FROM_EMAIL=
