{
  "buildCommand": "npm run build && cd sustainability/report_comparison && npm ci && npm run build && cp -r ../esg-export/. .",
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/about", "destination": "/about.html" },
    { "source": "/sides", "destination": "/sides/index.html" },
    { "source": "/talk", "destination": "/talk/index.html" },
    { "source": "/post", "destination": "/post.html" },
    { "source": "/typeme/u/:slug/rate", "destination": "/api/typeme/hub?slug=:slug&mode=rate" },
    { "source": "/typeme/u/:slug", "destination": "/api/typeme/hub?slug=:slug" },
    { "source": "/typeme", "destination": "/typeme/index.html" },
    { "source": "/sustainability/sr2026", "destination": "/sustainability/sr2026/index.html" },
    { "source": "/sustainability/report_comparison", "destination": "/sustainability/report_comparison/index.html" }
  ]
}
