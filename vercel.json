{
  "routes": [
    {
      "src": "/about",
      "dest": "/about.html"
    },
    {
      "src": "/sides",
      "dest": "/sides/index.html"
    },
    {
      "src": "/typeme/u/([^/]+)/rate/?",
      "dest": "/api/typeme/hub?slug=$1&mode=rate"
    },
    {
      "src": "/typeme/u/([^/]+)/?",
      "dest": "/api/typeme/hub?slug=$1"
    },
    {
      "src": "/typeme/?",
      "dest": "/typeme/index.html"
    },
    {
      "src": "/sustainability/sr2026",
      "dest": "/sustainability/sr2026/index.html"
    },
    {
      "src": "/sustainability/report_comparison(.*)",
      "dest": "https://temasek-esg-tracker.vercel.app/sustainability/report_comparison$1",
      "check": true
    }
  ]
}
